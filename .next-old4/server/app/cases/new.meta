{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/cases/layout,_N_T_/cases/new/layout,_N_T_/cases/new/page,_N_T_/cases/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/cases/new/__PAGE__",
    "/cases/new",
    "/cases",
    "/_index",
    "/_head"
  ]
}